VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Strongly recommended: legacy anon key (JWT, starts with eyJ...) from Dashboard → Settings → API.
# Used as createClient key → correct `apikey` header for Edge Functions.
VITE_SUPABASE_ANON_KEY=

# Optional: new publishable key. If you use only this, redeploy Edge Functions with verify_jwt=false
# (this repo sets that for `onboarding`) or you may see 401 Invalid JWT at the gateway.
# VITE_SUPABASE_PUBLISHABLE_KEY=
